# ============================================
# ГЛАВНЫЙ ПЕРЕКЛЮЧАТЕЛЬ
# Значения: "ollama" или "yandexgpt"
# ============================================
LLM_PROVIDER=ollama

# ============================================
# Ollama (Локальная модель)
# ============================================
OLLAMA_URL=http://localhost:11434/api/generate
OLLAMA_MODEL=qwen2.5:3b

# ============================================
# YandexGPT (Облачная модель)
# Заполни ключи, когда переключишься на yandexgpt
# ============================================
YANDEX_API_KEY=
YANDEX_FOLDER_ID=
YANDEX_MODEL=yandexgpt-lite

# ============================================
# GitHub API
# ============================================
GITHUB_TOKEN=

# ============================================
# Edge TTS (Озвучка)
# ============================================
VOICE=ru-RU-DmitryNeural

# ============================================
# Настройки приложения
# ============================================
DEBUG=True
REQUEST_TIMEOUT=600
MAX_TEXT_LENGTH=3000

# ============================================
# На будущее (База данных / Оплата)
# ============================================
DATABASE_URL=
YUKASSA_SECRET_KEY=
YUKASSA_SHOP_ID=